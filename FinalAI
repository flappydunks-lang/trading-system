class DataFetcher:
    """Enhanced data fetcher with crypto support."""
    
    def __init__(self):
        self.cache_dir = CACHE_DIR
    
    def is_crypto(self, ticker: str) -> bool:
        """Check if ticker is a cryptocurrency."""
        crypto_suffixes = ['-USD', '-USDT', 'USD', 'USDT']
        crypto_tickers = ['BTC', 'ETH', 'BNB', 'XRP', 'ADA', 'SOL', 'DOT', 'DOGE', 'MATIC', 'AVAX']
        
        return any(ticker.endswith(suffix) for suffix in crypto_suffixes) or \
               any(ticker.startswith(crypto) for crypto in crypto_tickers)
    
    def fetch_stock_data(self, ticker: str, period: str = "1y", 
                        interval: str = "1d") -> pd.DataFrame:
        """Fetch stock or crypto data with validation."""
        try:
            # Handle crypto tickers
            if self.is_crypto(ticker) and not ticker.endswith('-USD'):
                ticker = f"{ticker}-USD"
            
            console.print(f"[dim]Downloading {ticker} data ({period}, {interval})...[/dim]")
            
            df = yf.download(ticker, period=period, interval=interval, 
                           progress=False, auto_adjust=True)
            
            if df.empty:
                raise ValueError(f"No data available for {ticker}")
            
            if isinstance(df.columns, pd.MultiIndex):
                df.columns = df.columns.droplevel(1)
            
            required_cols = ['Open', 'High', 'Low', 'Close']
            missing_cols = [col for col in required_cols if col not in df.columns]
            if missing_cols:
                raise ValueError(f"Missing required columns: {missing_cols}")
            
            if 'Volume' not in df.columns:
                df['Volume'] = 0
                console.print(f"[yellow]⚠️  No volume data available for {ticker}[/yellow]")
            
            return df
            
        except Exception as e:
            logger.error(f"Error fetching {ticker}: {e}")
            raise ValueError(f"Failed to fetch data for {ticker}: {str(e)}")

