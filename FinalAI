class RiskCalculator:
    """Advanced risk management and position sizing."""
    
    @staticmethod
    def calculate_position_size(account_size: float, risk_percent: float, 
                               entry_price: float, stop_loss: float) -> RiskManagement:
        """Calculate optimal position size based on risk management rules."""
        
        # Risk amount
        risk_amount = account_size * (risk_percent / 100)
        
        # Stop loss distance
        stop_distance = abs(entry_price - stop_loss)
        stop_loss_percent = (stop_distance / entry_price) * 100
        
        # Position size
        position_size_shares = int(risk_amount / stop_distance)
        position_value = position_size_shares * entry_price
        position_size_percent = (position_value / account_size) * 100
        
        # Take profit levels (1:1, 1:2, 1:3 risk:reward)
        take_profit_levels = [
            (entry_price + stop_distance, "1:1 Risk:Reward"),
            (entry_price + (stop_distance * 2), "1:2 Risk:Reward"),
            (entry_price + (stop_distance * 3), "1:3 Risk:Reward")
        ]
        
        # Risk/Reward ratio (using 1:2 as default target)
        risk_reward_ratio = 2.0
        
        # Determine risk level
        if stop_loss_percent < 2:
            risk_level = "VERY_LOW"
        elif stop_loss_percent < 5:
            risk_level = "LOW"
        elif stop_loss_percent < 10:
            risk_level = "MEDIUM"
        elif stop_loss_percent < 15:
            risk_level = "HIGH"
        else:
            risk_level = "VERY_HIGH"
        
        return RiskManagement(
            position_size_percent=round(position_size_percent, 2),
            position_size_shares=position_size_shares,
            stop_loss_price=round(stop_loss, 2),
            stop_loss_percent=round(stop_loss_percent, 2),
            take_profit_levels=[(round(price, 2), desc) for price, desc in take_profit_levels],
            risk_reward_ratio=risk_reward_ratio,
            max_loss_amount=round(risk_amount, 2),
            risk_level=risk_level
        )

