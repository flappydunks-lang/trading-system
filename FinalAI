class PatternRecognition:
    """Advanced chart pattern recognition."""
    
    @staticmethod
    def detect_head_and_shoulders(df: pd.DataFrame) -> Optional[PatternDetection]:
        """Detect Head and Shoulders pattern."""
        if len(df) < 50:
            return None
        
        close = df['Close'].values
        maxima_indices = argrelextrema(close, np.greater, order=5)[0]
        
        if len(maxima_indices) < 3:
            return None
        
        recent_maxima = maxima_indices[-3:]
        peaks = close[recent_maxima]
        
        if len(peaks) == 3:
            left_shoulder, head, right_shoulder = peaks
            
            if head > left_shoulder and head > right_shoulder:
                if abs(left_shoulder - right_shoulder) / left_shoulder < 0.02:
                    neckline = (left_shoulder + right_shoulder) / 2
                    target = neckline - (head - neckline)
                    stop_loss = head * 1.02
                    
                    return PatternDetection(
                        pattern_name="Head and Shoulders",
                        confidence=75.0,
                        bullish=False,
                        description="Bearish reversal pattern detected",
                        entry_point=float(neckline),
                        target=float(target),
                        stop_loss=float(stop_loss)
                    )
        
        return None
    
    @staticmethod
    def detect_double_top_bottom(df: pd.DataFrame) -> Optional[PatternDetection]:
        """Detect Double Top/Bottom patterns."""
        if len(df) < 30:
            return None
        
        close = df['Close'].values
        maxima_indices = argrelextrema(close, np.greater, order=3)[0]
        
        if len(maxima_indices) >= 2:
            last_two_peaks = close[maxima_indices[-2:]]
            if abs(last_two_peaks[0] - last_two_peaks[1]) / last_two_peaks[0] < 0.02:
                peak_level = (last_two_peaks[0] + last_two_peaks[1]) / 2
                valley_idx = maxima_indices[-2] + np.argmin(close[maxima_indices[-2]:maxima_indices[-1]])
                valley_level = close[valley_idx]
                target = valley_level - (peak_level - valley_level)
                
                return PatternDetection(
                    pattern_name="Double Top",
                    confidence=70.0,
                    bullish=False,
                    description="Bearish reversal - two peaks at similar levels",
                    entry_point=float(valley_level),
                    target=float(target),
                    stop_loss=float(peak_level * 1.02)
                )
        
        minima_indices = argrelextrema(close, np.less, order=3)[0]
        
        if len(minima_indices) >= 2:
            last_two_troughs = close[minima_indices[-2:]]
            if abs(last_two_troughs[0] - last_two_troughs[1]) / last_two_troughs[0] < 0.02:
                trough_level = (last_two_troughs[0] + last_two_troughs[1]) / 2
                peak_idx = minima_indices[-2] + np.argmax(close[minima_indices[-2]:minima_indices[-1]])
                peak_level = close[peak_idx]
                target = peak_level + (peak_level - trough_level)
                
                return PatternDetection(
                    pattern_name="Double Bottom",
                    confidence=70.0,
                    bullish=True,
                    description="Bullish reversal - two troughs at similar levels",
                    entry_point=float(peak_level),
                    target=float(target),
                    stop_loss=float(trough_level * 0.98)
                )
        
        return None
    
    @staticmethod
    def detect_cup_and_handle(df: pd.DataFrame) -> Optional[PatternDetection]:
        """Detect Cup and Handle pattern."""
        if len(df) < 60:
            return None
        
        close = df['Close'].values[-60:]
        
        # Find the cup formation
        first_third = close[:20]
        middle_third = close[20:40]
        last_third = close[40:]
        
        # Cup should have U-shape
        if np.mean(first_third) > np.mean(middle_third) and np.mean(last_third) > np.mean(middle_third):
            # Check for handle (slight pullback)
            if np.mean(last_third[-10:]) < np.mean(last_third):
                rim_level = (first_third[0] + last_third[-1]) / 2
                depth = rim_level - np.min(middle_third)
                target = rim_level + depth
                
                return PatternDetection(
                    pattern_name="Cup and Handle",
                    confidence=65.0,
                    bullish=True,
                    description="Bullish continuation pattern with cup and handle formation",
                    entry_point=float(rim_level),
                    target=float(target),
                    stop_loss=float(np.min(close) * 0.98)
                )
        
        return None
    
    @staticmethod
    def detect_wedge(df: pd.DataFrame) -> Optional[PatternDetection]:
        """Detect Rising/Falling Wedge patterns."""
        if len(df) < 30:
            return None
        
        high = df['High'].values[-30:]
        low = df['Low'].values[-30:]
        close = df['Close'].values
        
        x = np.arange(len(high))
        high_slope = np.polyfit(x, high, 1)[0]
        low_slope = np.polyfit(x, low, 1)[0]
        
        # Rising Wedge (bearish)
        if high_slope > 0 and low_slope > 0 and high_slope < low_slope * 1.5:
            return PatternDetection(
                pattern_name="Rising Wedge",
                confidence=60.0,
                bullish=False,
                description="Bearish pattern - converging uptrend lines",
                entry_point=float(close[-1]),
                target=float(close[-1] * 0.95),
                stop_loss=float(close[-1] * 1.03)
            )
        
        # Falling Wedge (bullish)
        if high_slope < 0 and low_slope < 0 and abs(high_slope) > abs(low_slope) * 1.5:
            return PatternDetection(
                pattern_name="Falling Wedge",
                confidence=60.0,
                bullish=True,
                description="Bullish pattern - converging downtrend lines",
                entry_point=float(close[-1]),
                target=float(close[-1] * 1.05),
                stop_loss=float(close[-1] * 0.97)
            )
        
        return None
    
    def detect_all_patterns(self, df: pd.DataFrame) -> List[PatternDetection]:
        """Detect all chart patterns."""
        patterns = []
        
        try:
            pattern = self.detect_head_and_shoulders(df)
            if pattern:
                patterns.append(pattern)
        except:
            pass
        
        try:
            pattern = self.detect_double_top_bottom(df)
            if pattern:
                patterns.append(pattern)
        except:
            pass
        
        try:
            pattern = self.detect_cup_and_handle(df)
            if pattern:
                patterns.append(pattern)
        except:
            pass
        
        try:
            pattern = self.detect_wedge(df)
            if pattern:
                patterns.append(pattern)
        except:
            pass
        
        return patterns

