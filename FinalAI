                        key, value = line.split('=', 1)
                        env_vars[key.strip()] = value.strip().strip('"').strip("'")
        
        api_keys_needed = [
            {
                'name': 'ANTHROPIC_API_KEY',
                'current': ANTHROPIC_API_KEY,
                'description': 'Anthropic Claude API Key (REQUIRED)',
