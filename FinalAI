    def calculate_technical_score(self, indicators: TechnicalIndicators, style: TradingStyle) -> float:
        """Calculate technical score based on trading style."""
        scores = []
        
        if style == TradingStyle.DAY_TRADE:
            # Day trading focuses on short-term momentum
            if 40 <= indicators.rsi_9 <= 60:
                scores.append(80)
            elif indicators.rsi_9 < 30:
                scores.append(90)
            else:
                scores.append(30)
            
            # VWAP importance for day trading
            if indicators.price > indicators.vwap:
                scores.append(75)
            else:
                scores.append(25)
            
            # Volume critical for day trading
            if indicators.volume_ratio > 2.0:
                scores.append(85)
            elif indicators.volume_ratio > 1.5:
                scores.append(70)
            else:
                scores.append(40)
            
        elif style == TradingStyle.SWING_TRADE:
            # Swing trading focuses on medium-term trends
            if indicators.price > indicators.sma_20 > indicators.sma_50:
                scores.append(85)
            else:
                scores.append(35)
            
            if 40 <= indicators.rsi_14 <= 60:
                scores.append(75)
            elif indicators.rsi_14 < 30:
                scores.append(85)
            else:
                scores.append(30)
            
            if indicators.adx > 25:
                scores.append(80)
            else:
                scores.append(50)
                
        else:  # LONG_TERM
            # Long-term investing focuses on major trends
            if indicators.price > indicators.sma_50 > indicators.sma_200:
                scores.append(90)
            elif indicators.price > indicators.sma_200:
                scores.append(70)
            else:
                scores.append(30)
            
            if indicators.adx > 25:
                scores.append(75)
            else:
                scores.append(55)
        
        # Common indicators for all styles
        if indicators.macd > indicators.macd_signal:
            scores.append(75)
        else:
            scores.append(25)
        
        return round(np.mean(scores), 2)
    
