class NewsSentimentAnalyzer:
    """Analyze news sentiment from multiple sources."""
    
    def __init__(self, api_key: str = NEWS_API_KEY):
        self.api_key = api_key
        self.base_url = "https://newsapi.org/v2/everything"
    
    def fetch_news(self, ticker: str, days_back: int = 7) -> List[Dict[str, Any]]:
        """Fetch news articles for a ticker."""
        if not self.api_key:
            return []
        
        try:
            from_date = (datetime.now() - timedelta(days=days_back)).strftime('%Y-%m-%d')
            
            params = {
                'q': f"{ticker} stock",
                'from': from_date,
                'sortBy': 'relevancy',
                'language': 'en',
                'apiKey': self.api_key,
                'pageSize': 20
            }
            
            response = requests.get(self.base_url, params=params, timeout=10)
            
            if response.status_code == 200:
                data = response.json()
                return data.get('articles', [])
            else:
                logger.warning(f"News API error: {response.status_code}")
                return []
        
        except Exception as e:
            logger.error(f"Error fetching news: {e}")
            return []
    
    def analyze_sentiment_simple(self, text: str) -> float:
        """Simple sentiment analysis using keyword matching."""
        text_lower = text.lower()
        
        positive_words = [
            'surge', 'soar', 'rally', 'gain', 'rise', 'jump', 'climb', 'advance',
            'bullish', 'optimistic', 'growth', 'profit', 'beat', 'exceed', 'outperform',
            'strong', 'robust', 'recover', 'upgrade', 'breakthrough', 'innovation',
            'expansion', 'success', 'positive', 'boost', 'momentum'
        ]
        
        negative_words = [
            'plunge', 'crash', 'fall', 'drop', 'decline', 'slump', 'tumble', 'sink',
            'bearish', 'pessimistic', 'loss', 'miss', 'disappoint', 'concern', 'worry',
            'weak', 'struggle', 'downgrade', 'lawsuit', 'investigation', 'fraud',
            'bankruptcy', 'layoff', 'cut', 'reduce', 'negative', 'risk'
        ]
        
        positive_count = sum(1 for word in positive_words if word in text_lower)
        negative_count = sum(1 for word in negative_words if word in text_lower)
        
        total = positive_count + negative_count
        if total == 0:
            return 0.0
        
        return (positive_count - negative_count) / total
    
    def analyze_ticker_sentiment(self, ticker: str) -> NewsAnalysis:
        """Analyze overall sentiment for a ticker."""
        articles = self.fetch_news(ticker)
        
        if not articles:
            return NewsAnalysis(
                ticker=ticker,
                sentiment_score=0.0,
                sentiment_label="NEUTRAL",
                articles_analyzed=0,
                key_headlines=[],
                summary="No recent news available"
            )
        
        sentiments = []
        headlines = []
        
        for article in articles[:10]:
            title = article.get('title', '')
            description = article.get('description', '')
            text = f"{title} {description}"
            
            sentiment = self.analyze_sentiment_simple(text)
            sentiments.append(sentiment)
            headlines.append(title)
        
        avg_sentiment = np.mean(sentiments) if sentiments else 0.0
        
        if avg_sentiment > 0.3:
            label = "VERY_POSITIVE"
        elif avg_sentiment > 0.1:
            label = "POSITIVE"
        elif avg_sentiment < -0.3:
            label = "VERY_NEGATIVE"
        elif avg_sentiment < -0.1:
            label = "NEGATIVE"
        else:
            label = "NEUTRAL"
        
        summary = f"Analyzed {len(articles)} articles. Overall sentiment is {label.lower().replace('_', ' ')}."
        
        return NewsAnalysis(
            ticker=ticker,
            sentiment_score=round(avg_sentiment, 3),
            sentiment_label=label,
            articles_analyzed=len(articles),
            key_headlines=headlines[:5],
            summary=summary
        )

