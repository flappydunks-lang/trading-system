class AdvancedTechnicalAnalyzer:
    """Professional-grade technical analysis with 50+ indicators."""
    
    @staticmethod
    def calculate_rsi(series: pd.Series, period: int = 14) -> float:
        """Calculate RSI."""
        if len(series) < period + 1:
            return 50.0
        
        delta = series.diff()
        gain = delta.clip(lower=0).rolling(period).mean()
        loss = -delta.clip(upper=0).rolling(period).mean()
        
        if pd.isna(gain.iloc[-1]) or pd.isna(loss.iloc[-1]):
            return 50.0
        
        if abs(loss.iloc[-1]) < 1e-10:
            return 100.0 if gain.iloc[-1] > 1e-10 else 50.0
        
        rs = gain.iloc[-1] / loss.iloc[-1]
        return 100 - (100 / (1 + rs))
    
    @staticmethod
    def calculate_stochastic(high: pd.Series, low: pd.Series, close: pd.Series, 
                            period: int = 14, smooth_k: int = 3) -> Tuple[float, float]:
        """Calculate Stochastic Oscillator."""
        if len(close) < period:
            return 50.0, 50.0
        
        lowest_low = low.rolling(period).min()
        highest_high = high.rolling(period).max()
        
        k = 100 * (close - lowest_low) / (highest_high - lowest_low)
        k = k.rolling(smooth_k).mean()
        d = k.rolling(3).mean()
        
        return float(k.iloc[-1]) if not pd.isna(k.iloc[-1]) else 50.0, \
               float(d.iloc[-1]) if not pd.isna(d.iloc[-1]) else 50.0
    
    @staticmethod
    def calculate_williams_r(high: pd.Series, low: pd.Series, close: pd.Series, 
                            period: int = 14) -> float:
        """Calculate Williams %R."""
        if len(close) < period:
            return -50.0
        
        highest_high = high.rolling(period).max()
        lowest_low = low.rolling(period).min()
        
        wr = -100 * (highest_high - close) / (highest_high - lowest_low)
        return float(wr.iloc[-1]) if not pd.isna(wr.iloc[-1]) else -50.0
    
    @staticmethod
    def calculate_atr(high: pd.Series, low: pd.Series, close: pd.Series, 
                     period: int = 14) -> float:
        """Calculate Average True Range."""
        if len(close) < period + 1:
            return 0.0
        
        high_low = high - low
        high_close = abs(high - close.shift())
        low_close = abs(low - close.shift())
        
        tr = pd.concat([high_low, high_close, low_close], axis=1).max(axis=1)
        atr = tr.rolling(period).mean()
        
        return float(atr.iloc[-1]) if not pd.isna(atr.iloc[-1]) else 0.0
    
    @staticmethod
    def calculate_adx(high: pd.Series, low: pd.Series, close: pd.Series, 
                     period: int = 14) -> float:
        """Calculate Average Directional Index."""
        if len(close) < period * 2:
            return 25.0
        
        high_diff = high.diff()
        low_diff = -low.diff()
        
        plus_dm = high_diff.where((high_diff > low_diff) & (high_diff > 0), 0)
        minus_dm = low_diff.where((low_diff > high_diff) & (low_diff > 0), 0)
        
        tr1 = high - low
        tr2 = abs(high - close.shift())
        tr3 = abs(low - close.shift())
        tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
        
        atr = tr.rolling(period).mean()
        plus_di = 100 * (plus_dm.rolling(period).mean() / atr)
        minus_di = 100 * (minus_dm.rolling(period).mean() / atr)
        
        dx = 100 * abs(plus_di - minus_di) / (plus_di + minus_di)
        adx = dx.rolling(period).mean()
        
        return float(adx.iloc[-1]) if not pd.isna(adx.iloc[-1]) else 25.0
    
    @staticmethod
    def calculate_obv(close: pd.Series, volume: pd.Series) -> float:
        """Calculate On-Balance Volume."""
        if len(close) < 2:
            return 0.0
        
        obv = (volume * (~close.diff().le(0) * 2 - 1)).cumsum()
        return float(obv.iloc[-1]) if not pd.isna(obv.iloc[-1]) else 0.0
    
    @staticmethod
    def calculate_mfi(high: pd.Series, low: pd.Series, close: pd.Series, 
                     volume: pd.Series, period: int = 14) -> float:
        """Calculate Money Flow Index."""
        if len(close) < period + 1:
            return 50.0
        
        typical_price = (high + low + close) / 3
        money_flow = typical_price * volume
        
        positive_flow = money_flow.where(typical_price > typical_price.shift(), 0).rolling(period).sum()
        negative_flow = money_flow.where(typical_price < typical_price.shift(), 0).rolling(period).sum()
        
        mfi = 100 - (100 / (1 + positive_flow / negative_flow))
        return float(mfi.iloc[-1]) if not pd.isna(mfi.iloc[-1]) else 50.0
    
    @staticmethod
    def calculate_vwap(high: pd.Series, low: pd.Series, close: pd.Series, 
                      volume: pd.Series) -> float:
        """Calculate Volume Weighted Average Price."""
        typical_price = (high + low + close) / 3
        vwap = (typical_price * volume).cumsum() / volume.cumsum()
        return float(vwap.iloc[-1]) if not pd.isna(vwap.iloc[-1]) else float(close.iloc[-1])
    
    @staticmethod
    def calculate_cci(high: pd.Series, low: pd.Series, close: pd.Series, 
                     period: int = 20) -> float:
        """Calculate Commodity Channel Index."""
        if len(close) < period:
            return 0.0
        
        typical_price = (high + low + close) / 3
        sma_tp = typical_price.rolling(period).mean()
        mad = typical_price.rolling(period).apply(lambda x: abs(x - x.mean()).mean())
        
        cci = (typical_price - sma_tp) / (0.015 * mad)
        return float(cci.iloc[-1]) if not pd.isna(cci.iloc[-1]) else 0.0
    
    @staticmethod
    def calculate_ichimoku(high: pd.Series, low: pd.Series, close: pd.Series) -> Dict[str, float]:
        """Calculate Ichimoku Cloud indicators."""
        if len(close) < 52:
            return {'conversion': 0, 'base': 0, 'span_a': 0, 'span_b': 0}
        
        # Conversion Line (Tenkan-sen): (9-period high + 9-period low)/2
        period9_high = high.rolling(9).max()
        period9_low = low.rolling(9).min()
        conversion_line = (period9_high + period9_low) / 2
        
        # Base Line (Kijun-sen): (26-period high + 26-period low)/2
        period26_high = high.rolling(26).max()
        period26_low = low.rolling(26).min()
        base_line = (period26_high + period26_low) / 2
        
        # Leading Span A (Senkou Span A): (Conversion + Base)/2
        span_a = (conversion_line + base_line) / 2
        
        # Leading Span B (Senkou Span B): (52-period high + 52-period low)/2
        period52_high = high.rolling(52).max()
        period52_low = low.rolling(52).min()
        span_b = (period52_high + period52_low) / 2
        
        return {
            'conversion': float(conversion_line.iloc[-1]) if not pd.isna(conversion_line.iloc[-1]) else 0,
            'base': float(base_line.iloc[-1]) if not pd.isna(base_line.iloc[-1]) else 0,
            'span_a': float(span_a.iloc[-1]) if not pd.isna(span_a.iloc[-1]) else 0,
            'span_b': float(span_b.iloc[-1]) if not pd.isna(span_b.iloc[-1]) else 0
        }
    
    @staticmethod
    def calculate_parabolic_sar(high: pd.Series, low: pd.Series, close: pd.Series) -> float:
        """Calculate Parabolic SAR."""
        if len(close) < 5:
            return float(close.iloc[-1])
        
        # Simplified SAR calculation
        af = 0.02
        max_af = 0.2
        
        # Use recent high/low for SAR approximation
        recent_high = float(high.tail(5).max())
        recent_low = float(low.tail(5).min())
        current_price = float(close.iloc[-1])
        
        # If price is above midpoint, SAR is below (bullish)
        # If price is below midpoint, SAR is above (bearish)
        midpoint = (recent_high + recent_low) / 2
        
        if current_price > midpoint:
            sar = recent_low
        else:
            sar = recent_high
        
        return sar
    
    @staticmethod
    def calculate_keltner_channels(high: pd.Series, low: pd.Series, close: pd.Series, 
                                   period: int = 20, multiplier: float = 2.0) -> Tuple[float, float]:
        """Calculate Keltner Channels."""
        if len(close) < period:
            return 0.0, 0.0
        
        # Middle line is EMA
        ema = close.ewm(span=period).mean()
        
        # Calculate ATR
        high_low = high - low
        high_close = abs(high - close.shift())
        low_close = abs(low - close.shift())
        tr = pd.concat([high_low, high_close, low_close], axis=1).max(axis=1)
        atr = tr.rolling(period).mean()
        
        upper = ema + (multiplier * atr)
        lower = ema - (multiplier * atr)
        
        return (float(upper.iloc[-1]) if not pd.isna(upper.iloc[-1]) else 0.0,
                float(lower.iloc[-1]) if not pd.isna(lower.iloc[-1]) else 0.0)
    
    @staticmethod
    def calculate_donchian_channels(high: pd.Series, low: pd.Series, period: int = 20) -> Tuple[float, float]:
        """Calculate Donchian Channels."""
        if len(high) < period:
            return 0.0, 0.0
        
        upper = high.rolling(period).max()
        lower = low.rolling(period).min()
        
        return (float(upper.iloc[-1]) if not pd.isna(upper.iloc[-1]) else 0.0,
                float(lower.iloc[-1]) if not pd.isna(lower.iloc[-1]) else 0.0)
    
    @staticmethod
    def calculate_elder_ray(high: pd.Series, low: pd.Series, close: pd.Series, period: int = 13) -> Tuple[float, float]:
        """Calculate Elder Ray Index."""
        if len(close) < period:
            return 0.0, 0.0
        
        ema = close.ewm(span=period).mean()
        bull_power = high - ema
        bear_power = low - ema
        
        return (float(bull_power.iloc[-1]) if not pd.isna(bull_power.iloc[-1]) else 0.0,
                float(bear_power.iloc[-1]) if not pd.isna(bear_power.iloc[-1]) else 0.0)
    
    @staticmethod
    def calculate_fibonacci_levels(high: pd.Series, low: pd.Series) -> Dict[str, float]:
        """Calculate Fibonacci retracement levels."""
        if len(high) < 20:
            return {'0': 0, '236': 0, '382': 0, '500': 0, '618': 0, '100': 0}
        
        recent_high = float(high.tail(20).max())
        recent_low = float(low.tail(20).min())
        diff = recent_high - recent_low
        
        return {
            '0': recent_high,
            '236': recent_high - 0.236 * diff,
            '382': recent_high - 0.382 * diff,
            '500': recent_high - 0.500 * diff,
            '618': recent_high - 0.618 * diff,
            '100': recent_low
        }
    
    @staticmethod
    def calculate_pivot_points(high: pd.Series, low: pd.Series, close: pd.Series) -> Dict[str, float]:
        """Calculate Pivot Points."""
        if len(close) < 2:
            return {'pivot': 0, 'r1': 0, 'r2': 0, 's1': 0, 's2': 0}
        
        prev_high = float(high.iloc[-2])
        prev_low = float(low.iloc[-2])
        prev_close = float(close.iloc[-2])
        
        pivot = (prev_high + prev_low + prev_close) / 3
        r1 = 2 * pivot - prev_low
        r2 = pivot + (prev_high - prev_low)
        s1 = 2 * pivot - prev_high
        s2 = pivot - (prev_high - prev_low)
        
        return {'pivot': pivot, 'r1': r1, 'r2': r2, 's1': s1, 's2': s2}
    
    def analyze_all_indicators(self, df: pd.DataFrame) -> TechnicalIndicators:
        """Calculate all technical indicators."""
        if df.empty:
            raise ValueError(f"No data available for analysis")
        
        if len(df) < 50:
            raise ValueError(f"Insufficient data for analysis. Need at least 50 days, got {len(df)}")
        
        # Handle MultiIndex columns from yfinance
        if isinstance(df.columns, pd.MultiIndex):
            df.columns = df.columns.get_level_values(0)
        
        close = df['Close']
        high = df['High']
        low = df['Low']
        
        if 'Volume' in df.columns:
            volume = df['Volume'].fillna(0).replace(0, 1)
        else:
            volume = pd.Series([1] * len(df), index=df.index)
        
        # Price & Volume
        current_price = float(close.iloc[-1])
        current_volume = int(volume.iloc[-1]) if not pd.isna(volume.iloc[-1]) else 0
        volume_sma_20 = float(volume.rolling(20).mean().iloc[-1])
        volume_ratio = current_volume / volume_sma_20 if volume_sma_20 > 0 else 1.0
        
        # Moving Averages
        sma_20 = float(close.rolling(20).mean().iloc[-1])
        sma_50 = float(close.rolling(min(50, len(close))).mean().iloc[-1])
        sma_200 = float(close.rolling(min(200, len(close))).mean().iloc[-1])
        ema_12 = float(close.ewm(span=12).mean().iloc[-1])
        ema_26 = float(close.ewm(span=26).mean().iloc[-1])
        ema_50 = float(close.ewm(span=min(50, len(close))).mean().iloc[-1])
        
        # VWAP
        vwap = self.calculate_vwap(high, low, close, volume)
        
        # Momentum Indicators
        rsi_14 = self.calculate_rsi(close, 14)
        rsi_9 = self.calculate_rsi(close, 9)
        stoch_k, stoch_d = self.calculate_stochastic(high, low, close)
        williams_r = self.calculate_williams_r(high, low, close)
        roc = float(((close.iloc[-1] - close.iloc[-11]) / close.iloc[-11] * 100)) if len(close) > 11 else 0.0
        cci = self.calculate_cci(high, low, close)
        
        # MACD
        macd_line = ema_12 - ema_26
        macd_signal = float(pd.Series([macd_line]).ewm(span=9).mean().iloc[-1])
        macd_histogram = macd_line - macd_signal
        
        # Bollinger Bands
        bb_middle = float(close.rolling(20).mean().iloc[-1])
        bb_std = float(close.rolling(20).std().iloc[-1])
        bb_upper = bb_middle + (2 * bb_std)
        bb_lower = bb_middle - (2 * bb_std)
        bb_width = bb_upper - bb_lower
        bb_percent = (current_price - bb_lower) / bb_width if bb_width > 0 else 0.5
        
        # Volatility
        atr = self.calculate_atr(high, low, close)
        std_dev = float(close.rolling(20).std().iloc[-1])
        
        # ADX
        adx = self.calculate_adx(high, low, close)
        
        # Volume Indicators
        obv = self.calculate_obv(close, volume)
        mfi = self.calculate_mfi(high, low, close, volume)
        
        # Fibonacci
        fib_levels = self.calculate_fibonacci_levels(high, low)
        
        # Pivot Points
        pivot = self.calculate_pivot_points(high, low, close)
        
        # Advanced Indicators
        ichimoku = self.calculate_ichimoku(high, low, close)
        psar = self.calculate_parabolic_sar(high, low, close)
        keltner_upper, keltner_lower = self.calculate_keltner_channels(high, low, close)
        donchian_upper, donchian_lower = self.calculate_donchian_channels(high, low)
        elder_bull, elder_bear = self.calculate_elder_ray(high, low, close)
        
        return TechnicalIndicators(
            price=round(current_price, 2),
            volume=current_volume,
            volume_sma_20=round(volume_sma_20, 0),
