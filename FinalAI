                model="claude-sonnet-4-20250514",
                max_tokens=2000,
                messages=[{"role": "user", "content": prompt}]
            )
            
            response_text = message.content[0].text.strip()
            
            if response_text.startswith("```json"):
                response_text = response_text.replace("```json", "").replace("```", "").strip()
            elif response_text.startswith("```"):
                response_text = response_text.replace("```", "").strip()
            
            analysis = json.loads(response_text)
            
            return (
                float(analysis.get('confidence', 50)),
                analysis.get('reasoning', 'No reasoning provided'),
                analysis.get('recommendation', 'HOLD'),
                analysis.get('risk_level', 'MEDIUM')
            )
            
        except Exception as e:
            logger.error(f"AI analysis error: {e}")
            return 50.0, f"AI analysis failed: {str(e)}", "HOLD", "UNKNOWN"
    
    def analyze_stock(self, ticker: str, df: pd.DataFrame, 
                     style: TradingStyle, account_size: float = 10000) -> QuantAnalysis:
        """Perform complete quantitative analysis."""
        
        try:
            # Set trading style
            self.set_trading_style(style)
            config = self.trading_config
            
            # Technical indicators
            with console.status(f"[cyan]Calculating technical indicators for {style.value}...", spinner="dots"):
                technical = self.technical_analyzer.analyze_all_indicators(df)
            
            # Pattern recognition
            with console.status(f"[cyan]Detecting chart patterns...", spinner="dots"):
                patterns = self.pattern_recognizer.detect_all_patterns(df)
            
            # News sentiment (less important for day trading)
            news = None
            if NEWS_API_KEY and style != TradingStyle.DAY_TRADE:
                with console.status(f"[cyan]Analyzing news sentiment...", spinner="dots"):
                    news = self.news_analyzer.analyze_ticker_sentiment(ticker)
            
            # Insider trading (mainly for long-term)
            insider_trades = []
            insider_score = 0.0
            congressional_trades = []
            congressional_score = 0.0
            
            if style == TradingStyle.LONG_TERM:
                with console.status(f"[cyan]Checking insider activity...", spinner="dots"):
                    insider_trades = self.insider_analyzer.fetch_insider_trades(ticker)
                    insider_score = self.insider_analyzer.calculate_insider_score(insider_trades)
                    congressional_trades = self.insider_analyzer.fetch_congressional_trades(ticker)
                    congressional_score = self.insider_analyzer.calculate_congressional_score(congressional_trades)
            
            # Calculate scores
            technical_score = self.calculate_technical_score(technical, style)
            sentiment_score = ((news.sentiment_score + 1) / 2 * 100) if news else 50.0
            insider_score_pct = ((insider_score + 1) / 2 * 100)
            
            # AI analysis
            with console.status(f"[cyan]AI analyzing all data...", spinner="dots"):
                ai_conf, ai_reason, recommendation, risk = self.get_ai_analysis(
                    ticker, technical, patterns, news, insider_score, congressional_score, style
                )
            
            # Calculate overall score (weights adjusted by trading style)
            if style == TradingStyle.DAY_TRADE:
                weights = {'technical': 0.7, 'ai': 0.25, 'sentiment': 0.05, 'insider': 0.0}
            elif style == TradingStyle.SWING_TRADE:
                weights = {'technical': 0.5, 'ai': 0.3, 'sentiment': 0.15, 'insider': 0.05}
            else:  # LONG_TERM
                weights = {'technical': 0.3, 'ai': 0.35, 'sentiment': 0.2, 'insider': 0.15}
            
            overall = (
                technical_score * weights['technical'] +
                ai_conf * weights['ai'] +
                sentiment_score * weights['sentiment'] +
                insider_score_pct * weights['insider']
            )
            
            # Determine trend
            if technical.price > technical.sma_20 > technical.sma_50:
                trend = "UPTREND"
                strength = min(100, technical.adx + 20)
            elif technical.price < technical.sma_20 < technical.sma_50:
                trend = "DOWNTREND"
                strength = min(100, technical.adx + 20)
            else:
                trend = "SIDEWAYS"
                strength = 50.0
            
            # Risk management calculation
            risk_mgmt = None
            if recommendation in ["BUY", "STRONG_BUY"]:
                stop_loss = technical.price - (technical.atr * 2)
                risk_mgmt = self.risk_calculator.calculate_position_size(
                    account_size, 2.0, technical.price, stop_loss
                )
            
            return QuantAnalysis(
                ticker=ticker,
                timestamp=datetime.now().isoformat(),
                trading_style=config.description,
                technical_indicators=technical,
                trend=trend,
                strength=round(strength, 2),
                patterns=patterns,
                news_sentiment=news,
                insider_trades=insider_trades,
                recent_insider_score=round(insider_score, 3),
                congressional_trades=congressional_trades,
                congressional_score=round(congressional_score, 3),
                ai_confidence=round(ai_conf, 2),
                ai_reasoning=ai_reason,
                recommendation=recommendation,
                risk_level=risk,
                technical_score=round(technical_score, 2),
                sentiment_score=round(sentiment_score, 2),
                insider_score=round(insider_score_pct, 2),
                overall_score=round(overall, 2),
                risk_management=risk_mgmt
            )
            
        except Exception as e:
            logger.error(f"Analysis error for {ticker}: {e}")
            raise

