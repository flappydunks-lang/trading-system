        sell_value = sum(t.value for t in trades if t.transaction_type == "SELL")
        
        total = buy_value + sell_value
        if total == 0:
            return 0.0
        
        score = (buy_value - sell_value) / total
        return max(-1.0, min(1.0, score))
    
