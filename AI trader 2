            marker_text = '⚪ HOLD'
        
        signal_marker = go.Scatter(
            x=[current_time],
            y=[current_price],
            mode='markers+text',
            name=f'{signal_data["signal"]} Signal',
            marker=dict(
                color=marker_color,
                size=25,
                line=dict(color='white', width=3),
                symbol='circle'
            ),
            text=[marker_text],
