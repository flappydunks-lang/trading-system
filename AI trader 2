        )
        
        fig = go.Figure(
            data=[candlestick, bb_lower, bb_upper, ema_21, ema_50, 
                  stop_line, tp1_line, tp2_line, signal_marker],
            layout=layout
        )
        
        return pio.to_html(fig, full_html=False)
    
    def send_alert(self, signal_data):
        """Send desktop notification"""
        symbol = signal_data['symbol']
        signal = signal_data['signal']
        
        # Only alert on strong signals
        if signal not in ['BUY', 'SELL'] or signal_data['confidence'] < 65:
            return
        
        # Prevent spam
        now = time.time()
        alert_key = f"{symbol}_{signal}"
        if alert_key in self.last_alert:
            if now - self.last_alert[alert_key] < 1800:  # 30 minutes
                return
        
        self.last_alert[alert_key] = now
        
        # Create alert
        emoji = "🟢" if signal == 'BUY' else "🔴"
        title = f"{emoji} {signal} SIGNAL: {symbol}"
        
        message = f"Price: ${signal_data['price']:.2f}\n"
        message += f"Confidence: {signal_data['confidence']:.0f}%\n"
        message += f"Stop Loss: ${signal_data['stop_loss']:.2f}\n"
        message += f"Target: ${signal_data['take_profit_2']:.2f}\n"
        message += f"Position: {signal_data['position_size']} shares"
        
        try:
            notification.notify(
                title=title,
                message=message,
                app_name='Trading Dashboard',
                timeout=15
            )
        except:
            pass
        
        # Console alert
        print(f"\n{'='*90}")
        print(f"{emoji} {title}")
        print(f"{'='*90}")
        print(message)
        for reason in signal_data['reasons']:
            print(f"  • {reason}")
        print(f"{'='*90}\n")
    
    def monitor_watchlist(self, mode='swing', interval=300):
        """Monitor watchlist and send alerts"""
        print(f"\n🔍 Monitoring {len(self.watchlist)} stocks ({mode} trading)...")
        print(f"📊 Update interval: {interval} seconds")
        print(f"🔔 Desktop alerts enabled\n")
        
        while True:
            for symbol in self.watchlist:
                try:
                    signal = self.generate_signal(symbol, mode)
                    if signal:
                        self.signals[symbol] = signal
                        self.send_alert(signal)
                except Exception as e:
                    print(f"⚠️  Error monitoring {symbol}: {e}")
                
                time.sleep(2)  # Small delay between stocks
            
            time.sleep(interval)

