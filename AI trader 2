            line=dict(color='orange', width=2)
        )
        
        # Bollinger Bands
        bb_upper = go.Scatter(
            x=df.index,
            y=df['BB_Upper'],
            name='BB Upper',
            line=dict(color='gray', width=1, dash='dash'),
