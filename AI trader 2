    def get_stock_data(self, symbol, period='1y', interval='1d'):
        """Get stock data from yfinance (FREE)"""
        try:
            ticker = yf.Ticker(symbol)
            data = ticker.history(period=period, interval=interval)
            
            if len(data) < 50:
                print(f"⚠️  Insufficient data for {symbol}")
                return None
            
            return data
        except Exception as e:
            print(f"❌ Error fetching {symbol}: {e}")
            return None
    
    def get_current_price(self, symbol):
        """Get current price"""
        try:
            ticker = yf.Ticker(symbol)
            data = ticker.history(period='1d', interval='1m')
            if len(data) > 0:
                return data['Close'].iloc[-1]
            
            # Fallback to daily
            data = ticker.history(period='2d')
            return data['Close'].iloc[-1]
        except:
            return None
    
    def calculate_indicators(self, data):
        """Calculate technical indicators"""
        df = data.copy()
        
        # EMAs
        for period in [8, 13, 21, 50, 100, 200]:
            df[f'EMA_{period}'] = df['Close'].ewm(span=period, adjust=False).mean()
        
        # RSI
        delta = df['Close'].diff()
        gain = delta.where(delta > 0, 0).rolling(window=14).mean()
        loss = -delta.where(delta < 0, 0).rolling(window=14).mean()
        rs = gain / loss
        df['RSI'] = 100 - (100 / (1 + rs))
        
        # MACD
        df['EMA_12'] = df['Close'].ewm(span=12, adjust=False).mean()
        df['EMA_26'] = df['Close'].ewm(span=26, adjust=False).mean()
        df['MACD'] = df['EMA_12'] - df['EMA_26']
        df['MACD_Signal'] = df['MACD'].ewm(span=9, adjust=False).mean()
        df['MACD_Hist'] = df['MACD'] - df['MACD_Signal']
        
        # ATR
        high_low = df['High'] - df['Low']
        high_close = abs(df['High'] - df['Close'].shift())
        low_close = abs(df['Low'] - df['Close'].shift())
        ranges = pd.concat([high_low, high_close, low_close], axis=1)
        true_range = ranges.max(axis=1)
        df['ATR'] = true_range.rolling(14).mean()
        
        # Bollinger Bands
        df['BB_Mid'] = df['Close'].rolling(20).mean()
        bb_std = df['Close'].rolling(20).std()
        df['BB_Upper'] = df['BB_Mid'] + (bb_std * 2)
        df['BB_Lower'] = df['BB_Mid'] - (bb_std * 2)
        
        # Volume
        df['Volume_MA'] = df['Volume'].rolling(20).mean()
        df['Volume_Ratio'] = df['Volume'] / df['Volume_MA']
        
        return df
    
    def generate_signal(self, symbol, mode='swing'):
        """Generate buy/sell signal with ML"""
        
        # Set parameters based on mode
        if mode == 'swing':
            period = '6mo'
            interval = '1h'
            hold_days = 5
            return_threshold = 0.03  # 3% gain target
        else:  # long-term
            period = '2y'
            interval = '1d'
            hold_days = 20
            return_threshold = 0.05  # 5% gain target
        
        data = self.get_stock_data(symbol, period=period, interval=interval)
        if data is None or len(data) < 100:
            return None
        
        df = self.calculate_indicators(data)
        
        # Prepare features for ML
        feature_cols = ['RSI', 'MACD', 'MACD_Hist', 'ATR', 'Volume_Ratio', 'EMA_21', 'EMA_50']
        
        # Create feature dataframe
        df_features = df[feature_cols + ['Close']].copy()
        df_features = df_features.dropna()
        
        if len(df_features) < 100:
            return None
        
        # Create target (future return)
        df_features['Future_Return'] = df_features['Close'].shift(-hold_days) / df_features['Close'] - 1
        df_features['Target'] = (df_features['Future_Return'] > return_threshold).astype(int)
        df_features = df_features.dropna()
        
        if len(df_features) < 100:
            return None
        
        # Train ML model
        split = int(len(df_features) * 0.8)
        X_train = df_features[feature_cols].iloc[:split]
        y_train = df_features['Target'].iloc[:split]
        X_current = df_features[feature_cols].iloc[-1:]
        
        # Scale features
        scaler = StandardScaler()
        X_train_scaled = scaler.fit_transform(X_train)
        X_current_scaled = scaler.transform(X_current)
        
        # Train model
        model = RandomForestClassifier(n_estimators=100, max_depth=10, random_state=42)
        model.fit(X_train_scaled, y_train)
        
        # Get prediction
        probability = model.predict_proba(X_current_scaled)[0, 1]
        
        # Get current values
        current_price = self.get_current_price(symbol)
        if current_price is None:
            current_price = df['Close'].iloc[-1]
        
        latest = df.iloc[-1]
        rsi = latest['RSI']
        macd = latest['MACD']
        macd_signal = latest['MACD_Signal']
        atr = latest['ATR']
        volume_ratio = latest['Volume_Ratio']
        
        # Generate signal with multiple confirmations
        signal_type = 'HOLD'
        confidence = probability * 100
        reasons = []
        
        # ML says buy
        if probability >= 0.70:
            signal_type = 'BUY'
            reasons.append(f'ML Confidence: {probability*100:.1f}%')
        
        # RSI oversold
        if rsi < 35:
            if signal_type != 'SELL':
                signal_type = 'BUY'
            reasons.append(f'RSI Oversold ({rsi:.1f})')
            confidence = max(confidence, 65)
        
        # RSI overbought
        elif rsi > 75:
            signal_type = 'SELL'
            reasons.append(f'RSI Overbought ({rsi:.1f})')
            confidence = max(confidence, 70)
        
        # MACD crossover
        prev_macd = df['MACD'].iloc[-2]
        prev_signal = df['MACD_Signal'].iloc[-2]
        
        if macd > macd_signal and prev_macd <= prev_signal:
            if signal_type != 'SELL':
                signal_type = 'BUY'
            reasons.append('MACD Bullish Cross')
        elif macd < macd_signal and prev_macd >= prev_signal:
            signal_type = 'SELL'
            reasons.append('MACD Bearish Cross')
        
        # Trend confirmation
        if latest['EMA_21'] > latest['EMA_50']:
            reasons.append('Uptrend (EMA 21 > 50)')
        else:
            reasons.append('Downtrend (EMA 21 < 50)')
        
        # Volume confirmation
        if volume_ratio > 1.5:
            reasons.append(f'High Volume ({volume_ratio:.1f}x avg)')
        
        # Calculate risk metrics
        stop_loss = current_price - (atr * 2.5)
        take_profit_1 = current_price + (atr * 2)
        take_profit_2 = current_price + (atr * 3)
        
        risk_per_share = current_price - stop_loss
        max_risk = self.portfolio_value * 0.01  # 1% risk
        position_size = int(max_risk / risk_per_share) if risk_per_share > 0 else 0
        
        # Don't exceed 20% of portfolio
        max_position = self.portfolio_value * 0.20
        if position_size * current_price > max_position:
            position_size = int(max_position / current_price)
        
        return {
            'symbol': symbol,
            'mode': mode,
            'signal': signal_type,
            'confidence': confidence,
            'price': current_price,
            'rsi': rsi,
            'macd': macd,
            'macd_signal': macd_signal,
            'volume_ratio': volume_ratio,
            'stop_loss': stop_loss,
            'take_profit_1': take_profit_1,
            'take_profit_2': take_profit_2,
            'position_size': position_size,
            'risk_amount': risk_per_share * position_size,
            'potential_profit': (take_profit_2 - current_price) * position_size,
            'risk_reward': (take_profit_2 - current_price) / risk_per_share if risk_per_share > 0 else 0,
            'reasons': reasons,
            'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
            'data': df
        }
    
