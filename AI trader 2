        # Stop loss and take profit lines
        stop_line = go.Scatter(
            x=[df.index[-20], current_time],
            y=[signal_data['stop_loss'], signal_data['stop_loss']],
            mode='lines',
            name='Stop Loss',
            line=dict(color='red', width=2, dash='dot'),
            showlegend=True
        )
        
        tp1_line = go.Scatter(
            x=[df.index[-20], current_time],
            y=[signal_data['take_profit_1'], signal_data['take_profit_1']],
            mode='lines',
            name='Take Profit 1',
            line=dict(color='green', width=2, dash='dot'),
            showlegend=True
        )
        
        tp2_line = go.Scatter(
            x=[df.index[-20], current_time],
            y=[signal_data['take_profit_2'], signal_data['take_profit_2']],
            mode='lines',
            name='Take Profit 2',
            line=dict(color='lightgreen', width=2, dash='dot'),
            showlegend=True
        )
        
        # Layout
        title_text = f"{signal_data['symbol']} | {signal_data['signal']} ({signal_data['confidence']:.0f}% confidence)"
        
        layout = go.Layout(
            title=dict(text=title_text, font=dict(size=20, color='white')),
            xaxis=dict(title='Date', gridcolor='#333'),
            yaxis=dict(title='Price ($)', gridcolor='#333'),
            hovermode='x unified',
            template='plotly_dark',
