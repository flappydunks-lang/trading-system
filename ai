# -------------------------
class BatchScanner:
    """High-performance batch scanner for multiple assets"""
    
    def __init__(self, watchlist_manager):
        self.wm = watchlist_manager
        self.stock_fetcher = StockFetcher()
        self.edgar_fetcher = EdgarFetcher()
        self.news_fetcher = NewsAPIFetcher(CONFIG["NEWSAPI_KEY"])
        self.analyzer = TechnicalAnalyzer()
    
    def scan_watchlist(self, watchlist_name):
        """Scan entire watchlist efficiently"""
        assets = self.wm.get_assets(watchlist_name)
        if not assets:
            return []
        
        tickers = [asset[0] for asset in assets]
        results = []
        
        # Batch fetch stock data
        print(f"Fetching data for {len(tickers)} tickers...")
        stock_data = self.stock_fetcher.fetch_batch(tickers)
        
        # Process each ticker
        for ticker, asset_type, scan_scope in assets:
            df = stock_data.get(ticker)
            if df is None:
                continue
            
            # Calculate indicators
            df = self.analyzer.calculate_indicators(df)
            if df is None:
                continue
            
            # Generate signals
            confidence, signals = self.analyzer.generate_signals(df)
            
            # Add to results if above threshold
            if confidence >= CONFIG["ALERT_CONFIDENCE_THRESHOLD"]:
                results.append({
                    'ticker': ticker,
                    'confidence': confidence,
                    'signals': signals,
                    'data': df
                })
        
        # Sort by confidence
        results.sort(key=lambda x: x['confidence'], reverse=True)
        
        return results[:CONFIG["TOP_N_SIGNALS"]]

