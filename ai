class NewsAPIFetcher:
    """Async news fetcher for better performance"""
    
    def __init__(self, api_key):
        self.api_key = api_key
        self.base_url = "https://newsapi.org/v2/everything"
    
    async def fetch_headlines_async(self, query, page_size=5, session=None):
        if not self.api_key:
            return []
        
        cache_key = f"news_{query}_{page_size}"
        cached = cache.get(cache_key)
        if cached:
            return cached
        
        params = {
            "q": query, 
            "pageSize": page_size, 
            "sortBy": "relevancy", 
            "language": "en", 
            "apiKey": self.api_key
        }
        
        close_session = False
        if session is None:
            session = aiohttp.ClientSession()
            close_session = True
        
        try:
            async with session.get(
                self.base_url, 
                params=params, 
                timeout=aiohttp.ClientTimeout(total=CONFIG["REQUEST_TIMEOUT"])
            ) as response:
                j = await response.json()
                if j.get("status") == "ok":
                    headlines = [
                        f"{a.get('title', '')} — {(a.get('source') or {}).get('name', '')}" 
                        for a in j.get("articles", [])
                    ]
                    cache.set(cache_key, headlines)
                    return headlines
        except Exception as e:
            print(f"NewsAPI fetch error for {query}: {e}")
        finally:
            if close_session:
                await session.close()
        
        return []
    
    def fetch_headlines(self, query, page_size=5):
        """Sync wrapper for async method"""
        return asyncio.run(self.fetch_headlines_async(query, page_size))

