# MAIN SCANNER LOOP
# -------------------------
def main_scanner():
    """Optimized main scanner with batch processing"""
    wm = WatchlistManager()
    scanner = BatchScanner(wm)
    notif = NotificationManager()
    
    print("🚀 Optimized Market AI Scanner Started")
    print(f"Scan interval: {CONFIG['SCAN_INTERVAL_SECONDS']}s")
    print(f"Cache enabled: {CONFIG['ENABLE_CACHE']}")
    print(f"Max workers: {CONFIG['MAX_WORKERS']}")
    
    while True:
        try:
            start_time = time.time()
            watchlists = wm.list_watchlists()
            
            for watchlist in watchlists:
                print(f"\n📊 Scanning watchlist: {watchlist}")
                results = scanner.scan_watchlist(watchlist)
                
                for result in results:
                    ticker = result['ticker']
                    confidence = result['confidence']
                    signals = result['signals']
                    
                    # Log alert
                    reason = " | ".join(signals[:3])
                    wm.log_alert(watchlist, ticker, confidence, reason)
                    
                    # Send notification
                    msg = f"🎯 *Alert: {ticker}*\n"
                    msg += f"Confidence: {confidence:.2%}\n"
                    msg += f"Signals:\n" + "\n".join(f"• {s}" for s in signals[:3])
                    
                    notif.send_notifications(msg)
                    print(f"✅ Alert: {ticker} ({confidence:.2%})")
            
            elapsed = time.time() - start_time
            print(f"\n⏱️ Scan completed in {elapsed:.2f}s")
            
            # Sleep until next scan
            sleep_time = max(0, CONFIG['SCAN_INTERVAL_SECONDS'] - elapsed)
            if sleep_time > 0:
                time.sleep(sleep_time)
        
        except KeyboardInterrupt:
            print("\n👋 Scanner stopped by user")
            break
        except Exception as e:
            print(f"❌ Scanner error: {e}")
            time.sleep(60)  # Wait before retrying

if __name__ == "__main__":
    main_scanner()