class StockFetcher:
    """Optimized stock data fetcher with caching and batch support"""
    
    @staticmethod
    def fetch(ticker, period="3mo", interval="1d"):
        cache_key = f"stock_{ticker}_{period}_{interval}"
        cached = cache.get(cache_key)
        if cached is not None:
            return cached
        
        try:
            df = yf.download(ticker, period=period, interval=interval, progress=False, threads=False)
            if df.empty:
                cache.set(cache_key, None)
                return None
            df = df.dropna()
            cache.set(cache_key, df)
            return df
        except Exception as e:
            print(f"Stock fetch error for {ticker}: {e}")
            cache.set(cache_key, None)
            return None
    
    @staticmethod
    def fetch_batch(tickers, period="3mo", interval="1d"):
        """Fetch multiple tickers in parallel"""
        results = {}
        with ThreadPoolExecutor(max_workers=CONFIG["MAX_WORKERS"]) as executor:
            future_to_ticker = {
                executor.submit(StockFetcher.fetch, ticker, period, interval): ticker 
                for ticker in tickers
            }
            for future in as_completed(future_to_ticker):
                ticker = future_to_ticker[future]
                try:
                    results[ticker] = future.result()
                except Exception as e:
                    print(f"Error fetching {ticker}: {e}")
                    results[ticker] = None
        return results

