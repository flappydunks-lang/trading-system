# SEC EDGAR FETCHER (Optimized)
# -------------------------
class EdgarFetcher:
    """
    Optimized EDGAR fetcher with caching and async support.
    """
    
    COMPANY_TICKERS_URL = "https://www.sec.gov/files/company_tickers.json"
    SUBMISSIONS_URL_TEMPLATE = "https://data.sec.gov/submissions/CIK{}.json"
    
    def __init__(self):
        self.headers = {
            "User-Agent": CONFIG["SEC_USER_AGENT"], 
            "Accept-Encoding": "gzip, deflate"
        }
        self.ticker_to_cik = {}
        self._load_company_tickers()
    
    @lru_cache(maxsize=1)
    def _load_company_tickers(self):
        """Load and cache ticker-to-CIK mapping"""
        cache_key = "sec_ticker_map"
        cached = cache.get(cache_key)
        if cached:
            self.ticker_to_cik = cached
            return
        
        try:
            r = requests.get(
                self.COMPANY_TICKERS_URL, 
                headers=self.headers, 
                timeout=CONFIG["REQUEST_TIMEOUT"]
            )
            j = r.json()
            for v in j.values():
                ticker = v.get("ticker", "").upper()
                cik_str = str(v.get("cik_str", ""))
                if ticker and cik_str:
                    self.ticker_to_cik[ticker] = cik_str
            cache.set(cache_key, self.ticker_to_cik)
        except Exception as e:
            print(f"Error loading SEC company tickers: {e}")
    
    def get_cik_for_ticker(self, ticker):
        return self.ticker_to_cik.get(ticker.upper(), None)
    
    async def fetch_recent_filings_async(self, ticker, lookback_days=90, session=None):
        """Async filing fetch for better performance"""
        cache_key = f"edgar_{ticker}_{lookback_days}"
        cached = cache.get(cache_key)
        if cached:
            return cached
        
        cik = self.get_cik_for_ticker(ticker)
        if not cik:
            result = (0.5, ["No CIK mapping"])
            cache.set(cache_key, result)
            return result
        
        cik_padded = cik.zfill(10)
        url = self.SUBMISSIONS_URL_TEMPLATE.format(cik_padded)
        
        close_session = False
        if session is None:
            session = aiohttp.ClientSession()
            close_session = True
        
        try:
            async with session.get(
                url, 
                headers=self.headers, 
                timeout=aiohttp.ClientTimeout(total=CONFIG["REQUEST_TIMEOUT"])
            ) as response:
                if response.status != 200:
                    result = (0.6, [f"EDGAR fetch status {response.status}"])
                    cache.set(cache_key, result)
                    return result
                
                j = await response.json()
                recent = j.get("filings", {}).get("recent", {})
                forms = recent.get("form", [])
                dates = recent.get("filingDate", [])
                
                findings = []
                conf = 0.5
                cutoff = datetime.utcnow() - timedelta(days=lookback_days)
                
                for f, d in zip(forms, dates):
                    try:
                        fd = datetime.strptime(d, "%Y-%m-%d")
                    except:
                        continue
                    if fd < cutoff:
                        continue
                    
                    f_upper = f.upper()
                    if f_upper in ("8-K", "10-Q", "10-K", "4", "3", "6-K", "S-1", "SC 13D", "SC 13G"):
                        findings.append(f"{f} filed on {d}")
                        # Weight severity
                        if f_upper in ("8-K", "4", "3", "S-1"):
                            conf += 0.12
                        else:
                            conf += 0.07
                
                conf = min(0.95, conf)
                if not findings:
                    findings = ["No major filings in lookback window"]
                
                result = (conf, findings)
                cache.set(cache_key, result)
                return result
        except Exception as e:
            print(f"EDGAR fetch error for {ticker}: {e}")
            result = (0.6, [f"EDGAR error: {e}"])
            return result
        finally:
            if close_session:
                await session.close()
    
    def fetch_recent_filings(self, ticker, lookback_days=90):
        """Sync wrapper for async method"""
        return asyncio.run(self.fetch_recent_filings_async(ticker, lookback_days))
    
    async def fetch_batch_async(self, tickers, lookback_days=90):
        """Fetch filings for multiple tickers in parallel"""
        async with aiohttp.ClientSession() as session:
            tasks = [
                self.fetch_recent_filings_async(ticker, lookback_days, session) 
                for ticker in tickers
            ]
            results = await asyncio.gather(*tasks, return_exceptions=True)
            return {ticker: result for ticker, result in zip(tickers, results)}
    
    def fetch_batch(self, tickers, lookback_days=90):
        """Sync wrapper for batch async method"""
        return asyncio.run(self.fetch_batch_async(tickers, lookback_days))

