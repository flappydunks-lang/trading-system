class TechnicalAnalyzer:
    """Optimized technical analysis with vectorized operations"""
    
    @staticmethod
    def calculate_indicators(df):
        """Calculate all indicators in one pass"""
        if df is None or len(df) < 20:
            return None
        
        try:
            # Use vectorized operations
            df = df.copy()
            
            # RSI
            df['RSI'] = ta.momentum.RSIIndicator(df['Close'], window=14).rsi()
            
            # MACD
            macd = ta.trend.MACD(df['Close'])
            df['MACD'] = macd.macd()
            df['MACD_signal'] = macd.macd_signal()
            
            # Bollinger Bands
            bollinger = ta.volatility.BollingerBands(df['Close'], window=20, window_dev=2)
            df['BB_high'] = bollinger.bollinger_hband()
            df['BB_low'] = bollinger.bollinger_lband()
            df['BB_mid'] = bollinger.bollinger_mavg()
            
            # Volume moving average
            df['Volume_MA'] = df['Volume'].rolling(window=20).mean()
            
            # Moving averages
            df['SMA_20'] = df['Close'].rolling(window=20).mean()
            df['SMA_50'] = df['Close'].rolling(window=50).mean()
            
            return df
        except Exception as e:
            print(f"Technical analysis error: {e}")
            return None
    
    @staticmethod
    def generate_signals(df):
        """Generate trading signals from indicators"""
        if df is None or len(df) < 2:
            return 0.5, []
        
        signals = []
        score = 0.5
        
        try:
            latest = df.iloc[-1]
            prev = df.iloc[-2]
            
            # RSI signals
            if not np.isnan(latest['RSI']):
                if latest['RSI'] < 30:
                    signals.append("RSI oversold (<30)")
                    score += 0.15
                elif latest['RSI'] > 70:
                    signals.append("RSI overbought (>70)")
                    score -= 0.1
            
            # MACD crossover
            if not (np.isnan(latest['MACD']) or np.isnan(latest['MACD_signal'])):
                if prev['MACD'] < prev['MACD_signal'] and latest['MACD'] > latest['MACD_signal']:
                    signals.append("MACD bullish crossover")
                    score += 0.2
                elif prev['MACD'] > prev['MACD_signal'] and latest['MACD'] < latest['MACD_signal']:
                    signals.append("MACD bearish crossover")
                    score -= 0.15
            
            # Bollinger Bands
            if not (np.isnan(latest['BB_low']) or np.isnan(latest['BB_high'])):
                if latest['Close'] < latest['BB_low']:
                    signals.append("Price below lower Bollinger Band")
                    score += 0.12
                elif latest['Close'] > latest['BB_high']:
                    signals.append("Price above upper Bollinger Band")
                    score -= 0.08
            
            # Volume spike
            if not np.isnan(latest['Volume_MA']) and latest['Volume'] > latest['Volume_MA'] * 1.5:
                signals.append("Volume spike detected")
                score += 0.1
            
            # Moving average crossover
            if not (np.isnan(latest['SMA_20']) or np.isnan(latest['SMA_50'])):
                if prev['SMA_20'] < prev['SMA_50'] and latest['SMA_20'] > latest['SMA_50']:
                    signals.append("Golden cross (SMA 20 > SMA 50)")
                    score += 0.18
                elif prev['SMA_20'] > prev['SMA_50'] and latest['SMA_20'] < latest['SMA_50']:
                    signals.append("Death cross (SMA 20 < SMA 50)")
                    score -= 0.18
            
            score = max(0.0, min(1.0, score))
            
            if not signals:
                signals = ["No significant signals"]
            
            return score, signals
        except Exception as e:
            print(f"Signal generation error: {e}")
            return 0.5, ["Error generating signals"]

