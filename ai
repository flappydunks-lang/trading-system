DB_PATH = "ultimate_ai_realtime.db"

class WatchlistManager:
    def __init__(self, db_path=DB_PATH):
        self.conn = sqlite3.connect(db_path, check_same_thread=False)
        self.conn.execute("PRAGMA journal_mode=WAL")  # Write-Ahead Logging for better concurrency
        self.conn.execute("PRAGMA synchronous=NORMAL")  # Faster writes
        self.cur = self.conn.cursor()
        self._init_db()

    def _init_db(self):
        self.cur.executescript("""
        CREATE TABLE IF NOT EXISTS watchlists (
            id INTEGER PRIMARY KEY,
            name TEXT NOT NULL,
            ticker TEXT NOT NULL,
            asset_type TEXT DEFAULT 'stock',
            scan_scope TEXT DEFAULT 'short-term',
            UNIQUE(name, ticker)
        );
        CREATE INDEX IF NOT EXISTS idx_watchlist_name ON watchlists(name);
        CREATE INDEX IF NOT EXISTS idx_ticker ON watchlists(ticker);
        
        CREATE TABLE IF NOT EXISTS alerts (
            id INTEGER PRIMARY KEY,
            time TEXT NOT NULL,
            watchlist TEXT NOT NULL,
            ticker TEXT NOT NULL,
            confidence REAL NOT NULL,
            reason TEXT
        );
        CREATE INDEX IF NOT EXISTS idx_alert_time ON alerts(time);
        CREATE INDEX IF NOT EXISTS idx_alert_ticker ON alerts(ticker);
        """)
        self.conn.commit()

    def add_asset(self, watchlist, ticker, asset_type="stock", scan_scope="short-term"):
        try:
            self.cur.execute(
                "INSERT OR IGNORE INTO watchlists (name, ticker, asset_type, scan_scope) VALUES (?,?,?,?)",
                (watchlist, ticker.upper(), asset_type, scan_scope)
            )
            self.conn.commit()
            return True
        except Exception as e:
            print(f"Error adding asset {ticker}: {e}")
            return False

    def list_watchlists(self):
        cache_key = "watchlists_list"
        cached = cache.get(cache_key)
        if cached:
            return cached
        
        self.cur.execute("SELECT DISTINCT name FROM watchlists")
        result = [r[0] for r in self.cur.fetchall()]
        cache.set(cache_key, result)
        return result

    def get_assets(self, watchlist):
        cache_key = f"watchlist_{watchlist}"
        cached = cache.get(cache_key)
        if cached:
            return cached
        
        self.cur.execute(
            "SELECT ticker, asset_type, scan_scope FROM watchlists WHERE name=?", 
            (watchlist,)
        )
        result = [(r[0], r[1], r[2]) for r in self.cur.fetchall()]
        cache.set(cache_key, result)
        return result

    def log_alert(self, watchlist, ticker, confidence, reason):
        try:
            self.cur.execute(
                "INSERT INTO alerts (time, watchlist, ticker, confidence, reason) VALUES (?,?,?,?,?)",
                (datetime.utcnow().isoformat(), watchlist, ticker, confidence, reason)
            )
            self.conn.commit()
        except Exception as e:
            print(f"Error logging alert: {e}")

    def get_recent_alerts(self, limit=50):
        self.cur.execute(
            "SELECT time, watchlist, ticker, confidence, reason FROM alerts ORDER BY id DESC LIMIT ?", 
            (limit,)
        )
        return self.cur.fetchall()

